# Credentials for signing + notarizing the macOS DMG.
# Copy this file to `.env` (which is gitignored) and fill in real values.
# Used by `npm run dist` via scripts/release.sh.

# Your Apple ID email (the one on the paid Developer Program account).
APPLE_ID=danielspils@gmail.com

# An app-specific password generated at https://appleid.apple.com
# (Sign-In and Security -> App-Specific Passwords). NOT your normal password.
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Your 10-character Team ID (from your Developer ID Application certificate).
APPLE_TEAM_ID=U3C3294MXK
