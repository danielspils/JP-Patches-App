{
  "name": "jp-patches",
  "productName": "JP Patches",
  "version": "0.8.6",
  "description": "Roland JX-3P patch manager",
  "main": "main.js",
  "author": "Daniel Spils",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "test": "node --test test/*.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "setup-vendor": "node scripts/setup-vendor.mjs",
    "dist": "npm run setup-vendor && electron-builder --mac --arm64",
    "dist:unsigned": "npm run setup-vendor && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --arm64",
    "dist:win": "npm run setup-vendor && electron-builder --win --x64",
    "stats": "bash scripts/usage.sh"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "js-yaml": "^4.2.0",
    "jsdom": "^29.1.1"
  },
  "build": {
    "appId": "com.danielspils.jp-patches",
    "productName": "JP Patches",
    "afterAllArtifactBuild": "scripts/staple-dmg.js",
    "publish": {
      "provider": "github",
      "owner": "danielspils",
      "repo": "JP-Patches-App"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "main-filename-util.js",
      "preload.js",
      "renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "vendor/uv",
        "to": "uv"
      },
      {
        "from": "vendor/jx3p",
        "to": "jx3p"
      }
    ],
    "mac": {
      "category": "public.app-category.music",
      "icon": "build/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": "arm64"
        },
        {
          "target": "zip",
          "arch": "arm64"
        }
      ],
      "hardenedRuntime": true,
      "notarize": true,
      "gatekeeperAssess": false,
      "artifactName": "JP-Patches-${version}-${arch}-mac.${ext}",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "JP Patches needs microphone access to record tape dumps from your JX-3P's CMT (tape) audio output."
      }
    },
    "dmg": {
      "title": "JP Patches ${version}",
      "artifactName": "JP-Patches.${ext}"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": "x64"
        }
      ],
      "artifactName": "JP-Patches-${version}-${arch}-win.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JP Patches"
    }
  },
  "dependencies": {
    "electron-updater": "6.3.9"
  }
}
